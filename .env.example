# =========================================
# Vetivet - Environment Variables Example
# =========================================
# Copy this file to .env.local or set these variables in your system
# DO NOT commit actual values to the repository

# =========================================
# Spring Profile
# =========================================
SPRING_PROFILE=local

# =========================================
# Server Configuration
# =========================================
PORT=8080

# =========================================
# JWT Configuration (REQUIRED for production)
# =========================================
# Generate a strong secret key (minimum 256 bits / 32 characters)
# Example: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here

# JWT token expiration in milliseconds (default: 86400000 = 24 hours)
JWT_EXPIRATION=86400000

# =========================================
# Database Configuration
# =========================================
# For local development (H2):
SPRING_DATASOURCE_URL=jdbc:h2:mem:vetivetdb;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=

# For Supabase (production):
# SPRING_DATASOURCE_URL=jdbc:postgresql://your-supabase-host:5432/your-db
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=your_supabase_password

# For Azure SQL (production):
# SPRING_DATASOURCE_URL=jdbc:sqlserver://your-server.database.windows.net:1433;database=your-db;encrypt=true;trustServerCertificate=false;hostNameInCertificate=*.database.windows.net;loginTimeout=30
# SPRING_DATASOURCE_USERNAME=your_username
# SPRING_DATASOURCE_PASSWORD=your_password

# H2 Console (disable in production)
SPRING_H2_CONSOLE_ENABLED=true

# =========================================
# WhatsApp Configuration
# =========================================
# Your WhatsApp business number (with country code)
WHATSAPP_NUMBER=+51914867621

# Default message for WhatsApp notifications
WHATSAPP_DEFAULT_MESSAGE=Hola! Me gustaría agendar una cita para mi mascota.

# =========================================
# CORS Configuration
# =========================================
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# =========================================
# Logging
# =========================================
# Optional: set logging levels
# logging.level.com.vetivet=INFO
# logging.level.org.springframework.security=WARN

